<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <style>
    .portal-customer { background: linear-gradient(135deg, #ffe4ec 0%, #fff0f5 50%, #e8f5e9 100%); min-height: 100vh; }
    .portal-customer .card { border: none; border-radius: 20px; box-shadow: 0 10px 40px rgba(233,30,99,0.15); }
    .portal-customer .card-header { background: linear-gradient(90deg, #e91e63, #f06292); color: #fff; border-radius: 20px 20px 0 0; padding: 1.25rem; }
    .portal-customer .btn-reg { background: linear-gradient(90deg, #e91e63, #f06292); border: none; border-radius: 25px; padding: 12px; }
    .portal-customer .btn-reg:hover { opacity: 0.9; color: #fff; }
    .portal-customer a.text-portal { color: #c2185b; font-weight: 600; }
  </style>
</head>
<body class="portal-customer">
  <%- include('../partials/header') %>
  <div class="container py-5">
    <% if (typeof error === 'string' && error) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert"><%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg">
          <div class="card-header text-center">
            <h4 class="mb-0">🌸 Create Customer Account</h4>
            <p class="mb-0 small opacity-90">Join us to order fresh flowers.</p>
          </div>
          <div class="card-body p-4">
            <form action="/customer/register" method="POST">
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label">First Name</label>
                  <input type="text" class="form-control" name="firstName" required>
                </div>
                <div class="col-6">
                  <label class="form-label">Last Name</label>
                  <input type="text" class="form-control" name="lastName" required>
                </div>
              </div>
              <div class="mb-3 mt-2">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" name="email" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Password (min 6 characters)</label>
                <input type="password" class="form-control" name="password" required minlength="6">
              </div>
              <button type="submit" class="btn btn-reg btn-primary w-100 text-white">Register</button>
              <p class="mt-3 text-center mb-0">
                Already have an account? <a href="/customer/login" class="text-portal">Login</a>
              </p>
            </form>
          </div>
        </div>
        <p class="text-center mt-3">
          <a href="/" class="text-muted"><i class="bi bi-arrow-left"></i> Back to Home</a>
        </p>
      </div>
    </div>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
