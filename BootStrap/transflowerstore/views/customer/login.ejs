<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
  <style>
    .portal-customer { background: linear-gradient(135deg, #ffe4ec 0%, #fff0f5 50%, #e8f5e9 100%); min-height: 100vh; }
    .portal-customer .card { border: none; border-radius: 20px; box-shadow: 0 10px 40px rgba(233,30,99,0.15); }
    .portal-customer .card-header { background: linear-gradient(90deg, #e91e63, #f06292); color: #fff; border-radius: 20px 20px 0 0; padding: 1.25rem; }
    .portal-customer .btn-login { background: linear-gradient(90deg, #e91e63, #f06292); border: none; border-radius: 25px; padding: 12px; }
    .portal-customer .btn-login:hover { opacity: 0.9; color: #fff; }
    .portal-customer a.text-portal { color: #c2185b; font-weight: 600; }
  </style>
</head>
<body class="portal-customer">
  <%- include('../partials/header') %>
  <div class="container py-5">
    <% if (typeof error === 'string' && error) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert"><%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (typeof success === 'string' && success) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert"><%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <div class="row justify-content-center">
      <div class="col-md-5 col-lg-4">
        <div class="card shadow-lg">
          <div class="card-header text-center">
            <h4 class="mb-0">🌸 Customer Login</h4>
            <p class="mb-0 small opacity-90">Welcome back! Shop fresh flowers.</p>
          </div>
          <div class="card-body p-4">
            <form action="/customer/login" method="POST">
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control form-control-lg" name="email" required placeholder="your@email.com">
              </div>
              <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" class="form-control form-control-lg" name="password" required placeholder="••••••••">
              </div>
              <button type="submit" class="btn btn-login btn-primary w-100 text-white">Login</button>
              <p class="mt-3 text-center mb-0">
                New here? <a href="/customer/register" class="text-portal">Create account</a>
              </p>
            </form>
          </div>
        </div>
        <p class="text-center mt-3">
          <a href="/" class="text-muted"><i class="bi bi-arrow-left"></i> Back to Home</a>
        </p>
      </div>
    </div>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
