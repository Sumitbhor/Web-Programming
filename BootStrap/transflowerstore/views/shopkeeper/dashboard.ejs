<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>
  <div class="container my-4">
    <% if (typeof success === 'string' && success) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert"><%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (typeof error === 'string' && error) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert"><%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>Shopkeeper Dashboard</h2>
      <a href="/shopkeeper/add-product" class="btn btn-danger"><i class="bi bi-plus-lg"></i> Add Product</a>
    </div>
    <div class="row g-4">
      <% if (typeof products !== 'undefined' && products.length) { %>
        <% products.forEach((p) => { %>
          <div class="col-md-4 col-lg-3">
            <div class="card shadow-sm h-100">
              <img src="<%= p.image || '/image/rose (2).jpg' %>" class="card-img-top" style="height:180px;object-fit:cover" alt="<%= p.name %>">
              <div class="card-body">
                <h5 class="card-title"><%= p.name %></h5>
                <p class="card-text text-muted small"><%= p.description || '—' %></p>
                <p class="fw-bold">Rs. <%= p.price %></p>
                <div class="d-flex gap-2">
                  <a href="/shopkeeper/edit-product/<%= p._id %>" class="btn btn-outline-primary btn-sm">Edit</a>
                  <form action="/shopkeeper/delete-product/<%= p._id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this product?');">
                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="col-12 text-center py-5">
          <p class="text-muted">No products yet. Add your first product with an image.</p>
          <a href="/shopkeeper/add-product" class="btn btn-danger">Add Product</a>
        </div>
      <% } %>
    </div>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
