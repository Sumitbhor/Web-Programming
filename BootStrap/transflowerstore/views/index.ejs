<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <style>
    .index-hero {
      background: linear-gradient(120deg, #2d1b4e 0%, #1a0a2e 40%, #0d0221 100%);
      color: #fff;
      padding: 4rem 0 5rem;
      position: relative;
      overflow: hidden;
    }
    .index-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: url('/image/f3.jpg') center/cover;
      opacity: 0.15;
      z-index: 0;
    }
    .index-hero .container { position: relative; z-index: 1; }
    .index-hero h1 { font-weight: 800; text-shadow: 0 2px 20px rgba(0,0,0,0.3); }
    .index-hero .lead { opacity: 0.95; }
    .portal-cards { margin-top: -2rem; position: relative; z-index: 2; }
    .portal-card {
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.25);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      height: 100%;
      border: none;
    }
    .portal-card:hover { transform: translateY(-8px); box-shadow: 0 25px 70px rgba(0,0,0,0.3); }
    .portal-card.customer { background: linear-gradient(145deg, #ffe4ec, #fff0f5); }
    .portal-card.shopkeeper { background: linear-gradient(145deg, #1a1a2e, #16213e); color: #eee; }
    .portal-card .card-body { padding: 2rem; }
    .portal-card .card-title { font-weight: 700; font-size: 1.5rem; }
    .portal-card.customer .btn { background: #e91e63; border: none; border-radius: 50px; padding: 12px 24px; font-weight: 600; }
    .portal-card.customer .btn:hover { background: #c2185b; color: #fff; }
    .portal-card.shopkeeper .btn { background: linear-gradient(90deg, #e94560, #0f3460); border: none; border-radius: 50px; padding: 12px 24px; font-weight: 600; color: #fff; }
    .portal-card.shopkeeper .btn:hover { opacity: 0.9; color: #fff; }
    .section-title { font-weight: 800; color: #2d1b4e; margin-bottom: 2rem; }
    .featured-section { background: #f8f6fa; padding: 4rem 0; }
    .flower-card-home {
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      transition: transform 0.3s, box-shadow 0.3s;
      height: 100%;
      background: #fff;
    }
    .flower-card-home:hover { transform: translateY(-6px); box-shadow: 0 15px 40px rgba(0,0,0,0.12); }
    .flower-card-home img { height: 240px; object-fit: cover; width: 100%; }
    .flower-card-home .card-body { padding: 1.25rem; }
    .flower-card-home .price { font-weight: 700; color: #e91e63; font-size: 1.1rem; }
    .carousel-wrap { border-radius: 20px; overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.1); }
    .carousel-wrap .carousel-item img { height: 70vh; object-fit: cover; }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <% if (typeof success === 'string' && success) { %>
    <div class="alert alert-success alert-dismissible fade show m-3" role="alert"><%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
  <% } %>
  <% if (typeof error === 'string' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show m-3" role="alert"><%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
  <% } %>

  <!-- Hero + Portal cards -->
  <section class="index-hero">
    <div class="container text-center">
      <h1 class="display-4 mb-3">Fresh Flowers, Fresh Smiles</h1>
      <p class="lead mb-0">Delivering happiness across India — every bouquet tells a story.</p>
    </div>
    <div class="container portal-cards">
      <div class="row g-4 justify-content-center">
        <div class="col-md-6 col-lg-5">
          <div class="card portal-card customer">
            <div class="card-body text-center">
              <div class="mb-3" style="font-size: 3rem;">🌸</div>
              <h2 class="card-title">I'm a Customer</h2>
              <p class="card-text text-muted">Browse flowers, order bouquets, and get them delivered.</p>
              <a href="/customer/login" class="btn btn-primary me-2">Login</a>
              <a href="/customer/register" class="btn btn-outline-danger">Register</a>
              <p class="mt-3 mb-0 small"><a href="/products" class="text-decoration-none">Browse products without account →</a></p>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-lg-5">
          <div class="card portal-card shopkeeper">
            <div class="card-body text-center">
              <div class="mb-3" style="font-size: 3rem;">🏪</div>
              <h2 class="card-title text-white">I'm a Shopkeeper</h2>
              <p class="card-text opacity-75">Add your flower images, set prices, and manage your store.</p>
              <a href="/shopkeeper/login" class="btn btn-primary me-2">Login</a>
              <a href="/shopkeeper/register" class="btn btn-outline-light">Register</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Carousel -->
  <section class="py-4">
    <div class="container">
      <div class="carousel-wrap">
        <div id="storeCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            <div class="carousel-item active">
              <img src="/image/f1.jpg" class="d-block w-100" alt="Slide 1">
            </div>
            <div class="carousel-item">
              <img src="/image/f2.jpg" class="d-block w-100" alt="Slide 2">
            </div>
            <div class="carousel-item">
              <img src="/image/f3.jpg" class="d-block w-100" alt="Slide 3">
            </div>
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#storeCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#storeCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured flowers (from shopkeeper uploads in backend) -->
  <section class="featured-section">
    <div class="container">
      <h2 class="section-title text-center">Flowers from our shopkeepers</h2>
      <p class="text-center text-muted mb-4">Products added by store owners — images stored in backend.</p>
      <div class="row g-4">
        <% if (typeof featured !== 'undefined' && featured.length) { %>
          <% featured.forEach((p, i) => { %>
            <div class="col-6 col-md-4 col-lg-3">
              <div class="card flower-card-home">
                <img src="<%= p.image || '/image/rose (2).jpg' %>" alt="<%= p.name %>">
                <div class="card-body text-center">
                  <h5 class="card-title"><%= p.name %></h5>
                  <p class="card-text small text-muted mb-1"><%= p.description || 'Fresh from our store' %></p>
                  <p class="price mb-2">Rs. <%= p.price %></p>
                  <a href="/products" class="btn btn-sm btn-danger rounded-pill"><i class="bi bi-cart-plus"></i> View</a>
                </div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="col-12 text-center py-4">
            <p class="text-muted">No flowers added yet. Shopkeepers can login and add products with images.</p>
            <a href="/shopkeeper/login" class="btn btn-outline-primary">Shopkeeper Login</a>
          </div>
        <% } %>
      </div>
      <% if (typeof featured !== 'undefined' && featured.length) { %>
        <div class="text-center mt-4">
          <a href="/products" class="btn btn-danger rounded-pill px-4">View all products</a>
        </div>
      <% } %>
    </div>
  </section>

  <!-- Bestselling (static showcase) -->
  <section class="py-5 bg-white">
    <div class="container">
      <h2 class="section-title text-center">Bestselling bouquets</h2>
      <div class="row g-4">
        <div class="col-6 col-md-3">
          <div class="card flower-card-home">
            <img src="/image/red roses b.jpg" alt="Red Roses">
            <div class="card-body text-center">
              <h5>Red Roses</h5>
              <p class="price">Rs. 599</p>
              <a href="/products" class="btn btn-sm btn-danger rounded-pill">Add to Cart</a>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card flower-card-home">
            <img src="/image/tulip b.jpg" alt="Tulips">
            <div class="card-body text-center">
              <h5>Yellow Tulips</h5>
              <p class="price">Rs. 699</p>
              <a href="/products" class="btn btn-sm btn-danger rounded-pill">Add to Cart</a>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card flower-card-home">
            <img src="/image/orchid b.jpg" alt="Orchids">
            <div class="card-body text-center">
              <h5>White Orchids</h5>
              <p class="price">Rs. 799</p>
              <a href="/products" class="btn btn-sm btn-danger rounded-pill">Add to Cart</a>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="card flower-card-home">
            <img src="/image/lily b.jpg" alt="Lilies">
            <div class="card-body text-center">
              <h5>Pink Lilies</h5>
              <p class="price">Rs. 749</p>
              <a href="/products" class="btn btn-sm btn-danger rounded-pill">Add to Cart</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
  <script>AOS.init({ duration: 1000, once: true });</script>
</body>
</html>
